<!DOCTYPE html>
<html lang="en">
<%- include("../partials/admin-head", { title: "Feedback" }) %>
<body>
<%- include("../partials/admin-nav", { title: "Feedback" }) %>

<div class="section-header">
  <div class="section-title">Feedback moderation</div>
  <span class="badge badge-gray"><%= comments.length %> submissions</span>
</div>
<div class="table-wrap">
  <table>
    <thead>
      <tr><th>Reviewer</th><th>Rating</th><th>Message</th><th>Status</th><th></th></tr>
    </thead>
    <tbody>
      <% comments.forEach(c => { %>
        <tr style="vertical-align:top">
          <td>
            <div style="font-weight:600;color:#0f172a"><%= c.name %></div>
            <div class="text-muted"><%= c.email %></div>
          </td>
          <td>
            <div style="color:#f59e0b;font-size:14px;letter-spacing:1px"><%= "★".repeat(c.rating) + "☆".repeat(5-c.rating) %></div>
            <div class="text-muted"><%= c.rating %>/5</div>
          </td>
          <td style="max-width:320px;font-size:13px;color:#475569"><%= c.message %></td>
          <td><span class="badge <%= c.is_approved ? 'badge-green' : 'badge-yellow' %>"><%= c.is_approved ? "Approved" : "Pending" %></span></td>
          <td>
            <div class="td-actions">
              <form method="POST" action="/admin/feedback/<%= c.id %>/toggle">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="btn-action-sm"><%= c.is_approved ? "Hide" : "Approve" %></button>
              </form>
              <form method="POST" action="/admin/feedback/<%= c.id %>/delete" onsubmit="return confirm('Delete this comment?')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="btn-danger-sm">Delete</button>
              </form>
            </div>
          </td>
        </tr>
      <% }) %>
      <% if (!comments.length) { %>
        <tr class="empty-row"><td colspan="5">No feedback submissions yet.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include("../partials/admin-foot") %>
</body>
</html>
