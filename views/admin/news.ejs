<!DOCTYPE html>
<html lang="en">
<%- include("../partials/admin-head", { title: "News" }) %>
<body>
<%- include("../partials/admin-nav", { title: "News" }) %>

<div class="card">
  <div class="card-title"><%= editing ? "✏️ Edit article" : "➕ Add news article" %></div>
  <form method="POST" action="<%= editing ? `/admin/news/${editing.id}` : '/admin/news' %>">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="form-grid">
      <div>
        <label class="form-label">Slug</label>
        <input name="slug" required value="<%= editing ? editing.slug : '' %>" class="form-input" placeholder="article-slug" />
      </div>
      <div>
        <label class="form-label">Title</label>
        <input name="title" required value="<%= editing ? editing.title : '' %>" class="form-input" placeholder="Article headline" />
      </div>
      <div>
        <label class="form-label">Category</label>
        <input name="category" value="<%= editing ? (editing.category || '') : '' %>" class="form-input" placeholder="Product, Company, Engineering…" />
      </div>
      <div>
        <label class="form-label">Published date</label>
        <input type="date" name="published_at" required value="<%= editing ? new Date(editing.published_at).toISOString().slice(0,10) : '' %>" class="form-input" />
      </div>
      <div>
        <label class="form-label">Display order</label>
        <input type="number" name="order_index" value="<%= editing ? editing.order_index : 0 %>" class="form-input" />
      </div>
      <% if (editing) { %>
        <div style="display:flex;align-items:flex-end;padding-bottom:2px">
          <div class="checkbox-row">
            <input type="checkbox" name="is_active" id="is_active" <%= editing.is_active ? "checked" : "" %> />
            <label for="is_active">Visible on public site</label>
          </div>
        </div>
      <% } %>
      <div class="col-span-2">
        <label class="form-label">Summary</label>
        <textarea name="summary" rows="3" class="form-textarea" placeholder="Article excerpt…"><%= editing ? (editing.summary || '') : '' %></textarea>
      </div>
      <div class="col-span-2">
        <div class="form-actions">
          <button type="submit" class="btn btn-primary"><%= editing ? "Save changes" : "Publish article" %></button>
          <% if (editing) { %><a href="/admin/news" class="btn btn-ghost">Cancel</a><% } %>
        </div>
      </div>
    </div>
  </form>
</div>

<div class="section-header">
  <div class="section-title">All articles</div>
  <span class="badge badge-gray"><%= articles.length %> total</span>
</div>
<div class="table-wrap">
  <table>
    <thead>
      <tr><th>Title</th><th>Category</th><th>Published</th><th>Status</th><th></th></tr>
    </thead>
    <tbody>
      <% articles.forEach(a => { %>
        <tr>
          <td>
            <div style="font-weight:600;color:#0f172a"><%= a.title %></div>
            <div class="text-muted"><%= a.slug %></div>
          </td>
          <td><% if(a.category) { %><span class="badge badge-purple"><%= a.category %></span><% } else { %>—<% } %></td>
          <td><%= new Date(a.published_at).toISOString().slice(0,10) %></td>
          <td><span class="badge <%= a.is_active ? 'badge-green' : 'badge-gray' %>"><%= a.is_active ? "Published" : "Draft" %></span></td>
          <td>
            <div class="td-actions">
              <a href="/admin/news/<%= a.id %>/edit" class="btn-action-sm">Edit</a>
              <form method="POST" action="/admin/news/<%= a.id %>/delete" onsubmit="return confirm('Delete this article?')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="btn-danger-sm">Delete</button>
              </form>
            </div>
          </td>
        </tr>
      <% }) %>
      <% if (!articles.length) { %>
        <tr class="empty-row"><td colspan="5">No articles yet — write your first one above.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include("../partials/admin-foot") %>
</body>
</html>
