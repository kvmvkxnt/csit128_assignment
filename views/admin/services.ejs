<!DOCTYPE html>
<html lang="en">
<%- include("../partials/admin-head", { title: "Services" }) %>
<body>
<%- include("../partials/admin-nav", { title: "Services" }) %>

<div class="card">
  <div class="card-title"><%= editing ? "✏️ Edit service" : "➕ Add new service" %></div>
  <form method="POST" action="<%= editing ? `/admin/services/${editing.id}` : '/admin/services' %>">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="form-grid">
      <div>
        <label class="form-label">Slug</label>
        <input name="slug" required value="<%= editing ? editing.slug : '' %>" class="form-input" placeholder="cloud-compute" />
      </div>
      <div>
        <label class="form-label">Name</label>
        <input name="name" required value="<%= editing ? editing.name : '' %>" class="form-input" placeholder="Cloud Compute" />
      </div>
      <div>
        <label class="form-label">Icon key</label>
        <input name="icon" value="<%= editing ? (editing.icon || '') : '' %>" class="form-input" placeholder="server" />
      </div>
      <div>
        <label class="form-label">Starting price</label>
        <input name="starting_price" value="<%= editing ? (editing.starting_price || '') : '' %>" class="form-input" placeholder="$49/mo" />
      </div>
      <div class="col-span-2">
        <label class="form-label">Summary</label>
        <input name="summary" value="<%= editing ? (editing.summary || '') : '' %>" class="form-input" placeholder="One-line description shown on the services page" />
      </div>
      <div class="col-span-2">
        <label class="form-label">Details</label>
        <textarea name="details" rows="3" class="form-textarea" placeholder="Longer details…"><%= editing ? (editing.details || '') : '' %></textarea>
      </div>
      <div>
        <label class="form-label">Display order</label>
        <input type="number" name="order_index" value="<%= editing ? editing.order_index : 0 %>" class="form-input" />
      </div>
      <% if (editing) { %>
        <div style="display:flex;align-items:flex-end;padding-bottom:2px">
          <div class="checkbox-row">
            <input type="checkbox" name="is_active" id="is_active" <%= editing.is_active ? "checked" : "" %> />
            <label for="is_active">Visible on public site</label>
          </div>
        </div>
      <% } %>
      <div class="col-span-2">
        <div class="form-actions">
          <button type="submit" class="btn btn-primary"><%= editing ? "Save changes" : "Create service" %></button>
          <% if (editing) { %><a href="/admin/services" class="btn btn-ghost">Cancel</a><% } %>
        </div>
      </div>
    </div>
  </form>
</div>

<div class="section-header">
  <div class="section-title">All services</div>
  <span class="badge badge-gray"><%= services.length %> total</span>
</div>
<div class="table-wrap">
  <table>
    <thead>
      <tr><th>Name</th><th>Starting price</th><th>Status</th><th></th></tr>
    </thead>
    <tbody>
      <% services.forEach(s => { %>
        <tr>
          <td>
            <div style="font-weight:600;color:#0f172a"><%= s.name %></div>
            <div class="text-muted"><%= s.slug %></div>
          </td>
          <td style="font-weight:600"><%= s.starting_price || "—" %></td>
          <td><span class="badge <%= s.is_active ? 'badge-blue' : 'badge-gray' %>"><%= s.is_active ? "Active" : "Hidden" %></span></td>
          <td>
            <div class="td-actions">
              <a href="/admin/services/<%= s.id %>/edit" class="btn-action-sm">Edit</a>
              <form method="POST" action="/admin/services/<%= s.id %>/delete" onsubmit="return confirm('Delete <%= s.name %>?')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="btn-danger-sm">Delete</button>
              </form>
            </div>
          </td>
        </tr>
      <% }) %>
      <% if (!services.length) { %>
        <tr class="empty-row"><td colspan="4">No services yet — add one above.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include("../partials/admin-foot") %>
</body>
</html>
