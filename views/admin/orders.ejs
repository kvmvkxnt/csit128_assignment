<!DOCTYPE html>
<html lang="en">
<%- include("../partials/admin-head", { title: "Orders" }) %>
<body>
<%- include("../partials/admin-nav", { title: "Orders" }) %>

<div class="section-header">
  <div class="section-title">Orders</div>
  <span class="badge badge-gray"><%= orders.length %> total</span>
</div>
<div class="table-wrap">
  <table>
    <thead>
      <tr><th>Buyer</th><th>Type</th><th>Item</th><th>Price</th><th>Status</th><th>Date</th><th></th></tr>
    </thead>
    <tbody>
      <% orders.forEach(o => { %>
        <tr>
          <td>
            <div style="font-weight:600;color:#0f172a"><%= o.buyer_name %></div>
            <div class="text-muted"><%= o.buyer_email %></div>
          </td>
          <td><span class="badge badge-purple" style="text-transform:capitalize"><%= o.item_type %></span></td>
          <td style="font-weight:500"><%= o.item_name %></td>
          <td style="font-weight:600"><%= o.item_price || "—" %></td>
          <td>
            <form method="POST" action="/admin/orders/<%= o.id %>/status">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <select name="status" onchange="this.form.submit()" class="form-select" style="font-size:12px;padding:4px 8px">
                <% ["pending","fulfilled","cancelled"].forEach(s => { %>
                  <option value="<%= s %>" <%= o.status === s ? "selected" : "" %>><%= s.charAt(0).toUpperCase()+s.slice(1) %></option>
                <% }) %>
              </select>
            </form>
          </td>
          <td class="text-muted"><%= new Date(o.created_at).toISOString().slice(0,10) %></td>
          <td>
            <form method="POST" action="/admin/orders/<%= o.id %>/delete" onsubmit="return confirm('Delete this order?')">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button type="submit" class="btn-danger-sm">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
      <% if (!orders.length) { %>
        <tr class="empty-row"><td colspan="7">No orders yet.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include("../partials/admin-foot") %>
</body>
</html>
