<!DOCTYPE html>
<html lang="en">
<%- include("../partials/admin-head", { title: "Products" }) %>
<body>
<%- include("../partials/admin-nav", { title: "Products" }) %>

<div class="card">
  <div class="card-title"><%= editing ? "✏️ Edit product" : "➕ Add new product" %></div>
  <form method="POST" action="<%= editing ? `/admin/products/${editing.id}` : '/admin/products' %>">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="form-grid">
      <div>
        <label class="form-label">Slug</label>
        <input name="slug" required value="<%= editing ? editing.slug : '' %>" class="form-input" placeholder="edge-node-appliance" />
      </div>
      <div>
        <label class="form-label">Name</label>
        <input name="name" required value="<%= editing ? editing.name : '' %>" class="form-input" placeholder="Edge Node Appliance" />
      </div>
      <div>
        <label class="form-label">Category</label>
        <input name="category" value="<%= editing ? (editing.category || '') : '' %>" class="form-input" placeholder="Hardware" />
      </div>
      <div>
        <label class="form-label">Price</label>
        <input name="price" value="<%= editing ? (editing.price || '') : '' %>" class="form-input" placeholder="$299" />
      </div>
      <div>
        <label class="form-label">Image URL</label>
        <input name="image_url" value="<%= editing ? (editing.image_url || '') : '' %>" class="form-input" placeholder="https://..." />
      </div>
      <div>
        <label class="form-label">Display order</label>
        <input type="number" name="order_index" value="<%= editing ? editing.order_index : 0 %>" class="form-input" />
      </div>
      <div class="col-span-2">
        <label class="form-label">Description</label>
        <textarea name="description" rows="3" class="form-textarea" placeholder="Describe this product…"><%= editing ? (editing.description || '') : '' %></textarea>
      </div>
      <% if (editing) { %>
        <div class="col-span-2">
          <div class="checkbox-row">
            <input type="checkbox" name="is_active" id="is_active" <%= editing.is_active ? "checked" : "" %> />
            <label for="is_active">Visible on public site</label>
          </div>
        </div>
      <% } %>
      <div class="col-span-2">
        <div class="form-actions">
          <button type="submit" class="btn btn-primary"><%= editing ? "Save changes" : "Create product" %></button>
          <% if (editing) { %><a href="/admin/products" class="btn btn-ghost">Cancel</a><% } %>
        </div>
      </div>
    </div>
  </form>
</div>

<div class="section-header">
  <div class="section-title">All products</div>
  <span class="badge badge-gray"><%= products.length %> total</span>
</div>
<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Category</th>
        <th>Price</th>
        <th>Status</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% products.forEach(p => { %>
        <tr>
          <td>
            <div style="font-weight:600;color:#0f172a"><%= p.name %></div>
            <div class="text-muted"><%= p.slug %></div>
          </td>
          <td><%= p.category || "—" %></td>
          <td style="font-weight:600"><%= p.price || "—" %></td>
          <td><span class="badge <%= p.is_active ? 'badge-green' : 'badge-gray' %>"><%= p.is_active ? "Active" : "Hidden" %></span></td>
          <td>
            <div class="td-actions">
              <a href="/admin/products/<%= p.id %>/edit" class="btn-action-sm">Edit</a>
              <form method="POST" action="/admin/products/<%= p.id %>/delete" onsubmit="return confirm('Delete <%= p.name %>?')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="btn-danger-sm">Delete</button>
              </form>
            </div>
          </td>
        </tr>
      <% }) %>
      <% if (!products.length) { %>
        <tr class="empty-row"><td colspan="5">No products yet — add one above.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include("../partials/admin-foot") %>
</body>
</html>
