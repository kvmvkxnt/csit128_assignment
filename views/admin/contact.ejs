<!DOCTYPE html>
<html lang="en">
<%- include("../partials/admin-head", { title: "Contact requests" }) %>
<body>
<%- include("../partials/admin-nav", { title: "Contact requests" }) %>

<div class="section-header">
  <div class="section-title">Contact requests</div>
  <span class="badge badge-gray"><%= messages.length %> messages</span>
</div>
<div class="table-wrap">
  <table>
    <thead>
      <tr><th>From</th><th>Subject</th><th>Message</th><th>Status</th><th>Date</th><th></th></tr>
    </thead>
    <tbody>
      <% messages.forEach(m => { %>
        <tr style="vertical-align:top">
          <td>
            <div style="font-weight:600;color:#0f172a"><%= m.name %></div>
            <div class="text-muted"><%= m.email %></div>
          </td>
          <td style="font-weight:500;max-width:160px"><%= m.subject %></td>
          <td style="max-width:280px;font-size:13px;color:#475569"><%= m.message %></td>
          <td><span class="badge <%= m.is_read ? 'badge-gray' : 'badge-blue' %>"><%= m.is_read ? "Read" : "New" %></span></td>
          <td class="text-muted"><%= new Date(m.submitted_at).toISOString().slice(0,10) %></td>
          <td>
            <div class="td-actions">
              <form method="POST" action="/admin/contact/<%= m.id %>/toggle">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="btn-action-sm"><%= m.is_read ? "Mark unread" : "Mark read" %></button>
              </form>
              <form method="POST" action="/admin/contact/<%= m.id %>/delete" onsubmit="return confirm('Delete this message?')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="btn-danger-sm">Delete</button>
              </form>
            </div>
          </td>
        </tr>
      <% }) %>
      <% if (!messages.length) { %>
        <tr class="empty-row"><td colspan="6">No contact messages yet.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include("../partials/admin-foot") %>
</body>
</html>
